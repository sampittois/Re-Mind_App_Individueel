{
  "name": "stress-app-electron",
  "version": "1.0.0",
  "description": "Electron app for stress-app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:frontend": "npm --prefix ../frontend run build",
    "dist": "npm run build:frontend && electron-builder",
    "pack": "npm run build:frontend && electron-builder --dir"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.remind.stressapp",
    "productName": "Re-Mind",
    "icon": "../frontend/src/assets/logo_primary.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "renderer"
      },
      {
        "from": "../frontend/src/assets/logo_primary.png",
        "to": "app-icon.png"
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
